# Backend Configuration for Vercel Deployment
# Copy this file to .env and fill in your values

# Server Port (on Vercel, this is auto-set but included for local dev)
PORT=3000

# Brevo (Email Service)
# Get from: https://app.brevo.com/account/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MongoDB (Database)
# Get from: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=reelsy

# Supabase (Authentication & Admin API)
# Get from: https://supabase.com/dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET=kL9mN2pQ5rS7tU1vW3xY4zA6bC8dE0fG1hI2jK3lM4nO5pQ6rS7tU8vW9xY0z

# Log Level (optional)
LOG_LEVEL=info
